<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VPN_MAUI.View.SignInPage"
             BackgroundColor="Black">
    <ContentPage.Resources>
        <Style TargetType="Button">
            <Setter Property="TextColor" Value="White"></Setter>
            <Setter Property="BackgroundColor" Value="#00e5ff"></Setter>
            <Setter Property="HeightRequest" Value="100"></Setter>
            <Setter Property="WidthRequest" Value="350"></Setter>
            <Setter Property="CornerRadius" Value="25"></Setter>
            <Setter Property="Margin" Value="0,0,0,250"></Setter>
            <Setter Property="FontSize" Value="50"></Setter>
            <Setter Property="FontAttributes" Value="Bold"></Setter>
        </Style>
        <Style TargetType="Entry">
            <Setter Property="HeightRequest" Value="100"></Setter>
            <Setter Property="WidthRequest" Value="350"></Setter>
            <Setter Property="BackgroundColor" Value="Grey"></Setter>
            <Setter Property="TextColor" Value="Black"></Setter>
            <Setter Property="PlaceholderColor" Value="Black"></Setter>
            <Setter Property="FontSize" Value="30"></Setter>
            <Setter Property="HorizontalTextAlignment" Value="Center"></Setter>
        </Style>
        <Style TargetType="Border">
            <Setter Property="HeightRequest" Value="100"></Setter>
            <Setter Property="WidthRequest" Value="350"></Setter>
        </Style>
    </ContentPage.Resources>
    
    <ContentPage.Content>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition></RowDefinition>
            </Grid.RowDefinitions>   
            <Border StrokeThickness="2"
                    Grid.Column="0"
                    Margin="0,100,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="45,45,45,45"/>
                </Border.StrokeShape>
                <Entry 
                    x:Name="MenoSignIn" 
                    Placeholder="meno"></Entry>
            </Border>
            <Border StrokeThickness="2"
                    Grid.Column="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="45,45,45,45"/>
                </Border.StrokeShape>
                <Entry 
                    x:Name="HesloSignIn"
                    Placeholder="heslo" 
                    IsPassword="True"></Entry>
            </Border>
            <Border StrokeThickness="2"
                    Grid.Column="1"
                    Margin="0,250,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="45,45,45,45"/>
                </Border.StrokeShape>
                <Entry 
                    x:Name="HesloOverenie" 
                    Placeholder="zopakuj heslo" 
                    IsPassword="True"/>
            </Border>
            
            <Button Grid.Row="1"
                Grid.Column="1"
                x:Name="BtnSignIn" 
                Text="zaregistrovať sa" 
                WidthRequest="450"
                Clicked="BtnCreate_OnClicked">
                <Button.GestureRecognizers>
                    <PointerGestureRecognizer 
                        PointerEntered="PointerGestureRecognizer_OnPointerEntered"
                        PointerExited="PointerGestureRecognizer_OnPointerExited"/>
                </Button.GestureRecognizers>
            </Button>
            <Button Grid.Column="0"
                Grid.Row="1"
                x:Name="BtnNoSignIn" 
                Text="späť" 
                Clicked="BtnNoCreate_OnClicked">
                <Button.GestureRecognizers>
                    <PointerGestureRecognizer
                        PointerEntered="PointerGestureRecognizer2_OnPointerEntered"
                        PointerExited="PointerGestureRecognizer2_OnPointerExited"/>
                </Button.GestureRecognizers>
            </Button>
        </Grid>
    </ContentPage.Content>
</ContentPage>